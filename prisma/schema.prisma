// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// PRODUCT
// A sellable item (e.g. "Blue Sneaker – Size 10")
// ─────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2) // stored in smallest currency unit or decimal
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A product can exist in many warehouses
  inventories Inventory[]

  @@map("products")
}

// ─────────────────────────────────────────────
// WAREHOUSE
// A physical location that holds stock
// ─────────────────────────────────────────────
model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories Inventory[]

  @@map("warehouses")
}

// ─────────────────────────────────────────────
// INVENTORY
// Stock levels for one product in one warehouse.
//
// availableStock = totalUnits - reservedUnits
//
// CONCURRENCY NOTE:
// The `reservedUnits` column is updated atomically using a
// Postgres UPDATE … WHERE with a row-level lock (SELECT FOR UPDATE)
// inside a transaction. This prevents two simultaneous reservations
// from double-spending the same unit.
// ─────────────────────────────────────────────
model Inventory {
  id            String   @id @default(cuid())
  productId     String
  warehouseId   String
  totalUnits    Int      @default(0) // physical units in warehouse
  reservedUnits Int      @default(0) // units currently held by pending reservations
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product     Product      @relation(fields: [productId], references: [id])
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  reservations Reservation[]

  // One row per product–warehouse pair
  @@unique([productId, warehouseId])
  @@map("inventories")
}

// ─────────────────────────────────────────────
// RESERVATION STATUS
// pending   → hold is active, waiting for payment
// confirmed → payment succeeded, stock permanently decremented
// released  → payment failed / expired / user cancelled; units freed
// ─────────────────────────────────────────────
enum ReservationStatus {
  pending
  confirmed
  released
}

// ─────────────────────────────────────────────
// RESERVATION
// A temporary hold on `quantity` units of a product in a warehouse.
//
// Lifecycle:
//   POST /api/reservations          → status: pending,    expiresAt: now + 10 min
//   POST /api/reservations/:id/confirm → status: confirmed  (if not expired)
//   POST /api/reservations/:id/release → status: released   (early cancel)
//   Cron / lazy cleanup             → status: released   (expiresAt passed)
// ─────────────────────────────────────────────
model Reservation {
  id          String            @id @default(cuid())
  inventoryId String
  quantity    Int               // number of units held
  status      ReservationStatus @default(pending)
  expiresAt   DateTime          // set to createdAt + 10 minutes on creation
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  // Idempotency key (optional bonus): unique per client retry key
  idempotencyKey String? @unique

  @@index([status, expiresAt]) // speeds up the expiry cleanup query
  @@map("reservations")
}

// ─────────────────────────────────────────────
// IDEMPOTENCY KEY (bonus)
// Stores the cached response for a given client key so that
// retried POST requests return the original result without
// repeating side effects.
// ─────────────────────────────────────────────
model IdempotencyRecord {
  key          String   @id               // value of the Idempotency-Key header
  responseBody Json                        // the full JSON response body we returned
  statusCode   Int                         // HTTP status code we returned
  createdAt    DateTime @default(now())
  expiresAt    DateTime                    // TTL – safe to delete after this

  @@index([expiresAt])
  @@map("idempotency_records")
}
